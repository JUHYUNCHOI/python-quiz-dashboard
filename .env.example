# ⚠️ 모든 변수는 NEXT_PUBLIC_ 접두사 → 빌드 시점에 클라이언트 번들로 박힘.
#    Vercel 프로젝트(=coderin) Settings → Environment Variables 에 반드시 등록.
#    하나라도 비면 빌드/기능이 깨짐 → next.config.mjs 가 빌드 시작 시 검증함.

# ── 필수 (없으면 production 빌드 중단) ──
# Supabase 인증·DB
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── 선택 (없으면 해당 기능만 비활성, 경고만) ──
# 선생님 등록용 비밀 코드
NEXT_PUBLIC_TEACHER_SECRET_CODE=your-secret-code

# 코드 실행 서버 (Piston) — 레슨/연습/복습의 코드 실행
NEXT_PUBLIC_PISTON_URL=https://YOUR_PISTON_HOST
NEXT_PUBLIC_PISTON_KEY=your-piston-key

# 외부 플랫폼 연동 링크
NEXT_PUBLIC_ALGORITHM_URL=https://YOUR_ALGORITHM_LAB_URL
NEXT_PUBLIC_CODEQUEST_URL=https://YOUR_CODEQUEST_URL
